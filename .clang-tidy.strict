# Strict mode: broader check set (still excludes known-noisy checks).
Checks: >
  -*,
  clang-analyzer-*,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  clang-analyzer-optin.core*,
  clang-analyzer-optin.portability.UnixAPI,
  clang-analyzer-optin.performance.Padding,
  bugprone-*,
  security-*,
  cert-*,
  misc-*,
  performance-*,
  readability-*,
  portability-*,
  clang-diagnostic-sign-compare,
  clang-diagnostic-implicit-fallthrough,
  clang-diagnostic-tautological-pointer-compare,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -readability-function-cognitive-complexity,
  -readability-function-size,
  -readability-identifier-length,
  -readability-identifier-naming,
  -readability-magic-numbers,
  -readability-uppercase-literal-suffix,
  -readability-isolate-declaration,
  -readability-non-const-parameter,
  -readability-math-missing-parentheses,
  -misc-no-recursion,
  -misc-unused-parameters,
  -misc-include-cleaner
WarningsAsErrors: 'clang-analyzer-*,security-*,bugprone-*,performance-*,portability-*,misc-redundant-expression,misc-static-assert,misc-use-internal-linkage,cert-str34-c,cert-flp30-c,clang-diagnostic-sign-compare,clang-diagnostic-implicit-fallthrough,clang-diagnostic-tautological-pointer-compare'
HeaderFilterRegex: '(^|.*/)(include|examples|bench|src/(core|ambe|imbe|ecc|internal))/'
FormatStyle: none
CheckOptions:
  - key: bugprone-branch-clone.MinLines
    value: '5'
  - key: bugprone-branch-clone.MinStructuralSimilarity
    value: '0.9'
  - key: bugprone-reserved-identifier.AllowedIdentifiers
    value: '_GNU_SOURCE;_USE_MATH_DEFINES'
